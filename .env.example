# SafeCheck environment configuration.
# Copy this file to ".env" and adjust as needed (setup.bat does this for you).
# All values are optional — sensible defaults live in safecheck/config.py.

# URL the field app uploads inspections to.
SAFECHECK_SYNC_SERVER_URL=http://127.0.0.1:8077

# Seconds before a sync attempt times out.
SAFECHECK_SYNC_TIMEOUT=5

# Central database path for the FastAPI server (blank = data/central.db).
SAFECHECK_CENTRAL_DB=

# Password applied to the seeded demo users. CHANGE FOR ANY REAL DEPLOYMENT.
SAFECHECK_DEMO_PASSWORD=safecheck

# Photograph handling.
SAFECHECK_PHOTO_MAX_DIMENSION=1280
SAFECHECK_PHOTO_JPEG_QUALITY=70
SAFECHECK_MAX_UPLOAD_BYTES=8388608

# Logging level: DEBUG, INFO, WARNING, ERROR.
SAFECHECK_LOG_LEVEL=INFO
